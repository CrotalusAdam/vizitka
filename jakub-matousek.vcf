<!DOCTYPE html>
<html>
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">

<!-- automatické otevření vCard -->

<style>
body {
  margin: 0;
  min-height: 100vh;
  display: flex;
  justify-content: center;
  align-items: center;
  background: #1f1f1f;
  font-family: Arial;
}

.card {
  max-width: 320px;
  background: white;
  border-radius: 12px;
  overflow: hidden;
  text-align: center;
  box-shadow: 0 8px 20px rgba(0,0,0,0.3);
}

.card img {
  width: 100%;
}

h1 {
  margin: 10px 0 5px;
}

.title {
  color: #1e90c2; /* barva z loga */
  font-weight: bold;
}

a.btn {
  display: block;
  padding: 15px;
  background: #1e90c2;
  color: white;
  text-decoration: none;
  font-size: 18px;
}

a.btn:hover {
  background: #167aa3;
}
</style>
</head>

<body>

<div class="card">
  <img src="jakub.jpeg" alt="Jakub">
  <h1>Jakub Matoušek</h1>
  <p class="title">Solution Consultant</p>
  <p>Technodat</p>
  <p>Zlín, Czechia</p>

  <a href="jakub-matousek.vcf" class="btn">
    📇 Uložit kontakt
  </a>
</div>

</body>
</html>